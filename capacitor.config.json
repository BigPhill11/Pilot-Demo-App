{
  "appId": "com.philsfinancials.app",
  "appName": "Phil's Financials",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#1a4d1a",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1a4d1a"
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    }
  },
  "ios": {
    "contentInset": "always",
    "scrollEnabled": true,
    "backgroundColor": "#1a4d1a"
  },
  "android": {
    "backgroundColor": "#1a4d1a",
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
